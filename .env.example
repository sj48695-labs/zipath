# ============================================
# Zipath 환경변수 설정
# ============================================

# 공공데이터포털 API 키 (https://www.data.go.kr)
# 청약홈 분양정보, 아파트매매 실거래가 등에 사용
DATA_GO_KR_API_KEY=your_api_key_here

# ============================================
# Backend (NestJS) - Railway 배포 시 자동 설정됨
# ============================================

# PostgreSQL 연결 URL
# Railway: 자동 제공 | 로컬: postgresql://user:password@localhost:5432/zipath
DATABASE_URL=postgresql://user:password@localhost:5432/zipath

# 서버 포트 (Railway: 자동 제공 | 로컬: 4000)
PORT=4000

# ============================================
# Frontend (Next.js) - Vercel 환경변수에 설정
# ============================================

# NestJS 백엔드 API URL (배포 후 설정)
# NEXT_PUBLIC_API_URL=https://your-railway-app.up.railway.app
