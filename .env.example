# ============================================
# Zipath 환경변수 설정
# ============================================

# 공공데이터포털 API 키 (https://www.data.go.kr)
# 청약홈 분양정보, 아파트매매 실거래가 등에 사용
DATA_GO_KR_API_KEY=your_api_key_here

# ============================================
# Backend (NestJS) - Render 배포 시 환경변수에 설정
# ============================================

# PostgreSQL 연결 URL
# 로컬: docker compose up -d 실행 후 아래 기본값 사용
# 프로덕션: Neon (https://neon.tech) 연결 URL
DATABASE_URL=postgresql://zipath:zipath@localhost:5432/zipath

# 서버 포트 (Render: 자동 제공 | 로컬: 4000)
PORT=4000

# JWT 시크릿 (프로덕션에서는 반드시 변경)
JWT_SECRET=zipath-dev-secret

# OAuth 설정 (각 Provider 개발자 콘솔에서 발급)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# ============================================
# Frontend (Next.js) - Vercel 환경변수에 설정
# ============================================

# NestJS 백엔드 API URL (배포 후 설정)
# NEXT_PUBLIC_API_URL=https://zipath-api.onrender.com
